{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://rag-python-doc-api.onrender.com/api/:path*"
    },
    {
      "source": "/healthz",
      "destination": "https://rag-python-doc-api.onrender.com/healthz"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
